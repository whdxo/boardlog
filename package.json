{
  "name": "boardlog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:validate": "node --env-file=.env.local ./node_modules/prisma/build/index.js validate --config prisma.config.js",
    "prisma:generate": "node --env-file=.env.local ./node_modules/prisma/build/index.js generate --config prisma.config.js",
    "prisma:migrate:board-games": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate dev --config prisma.config.js --name add_board_game_catalog",
    "prisma:studio": "node --env-file=.env.local ./node_modules/prisma/build/index.js studio --config prisma.config.js",
    "seed:bgg:ranks": "node --env-file=.env.local scripts/seed-bgg-ranks.ts"
  },
  "prisma": {
    "seed": "node --env-file=.env.local scripts/seed-bgg-ranks.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/pretendard": "^5.2.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.96.1",
    "caniuse-lite": "^1.0.30001787",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@prisma/client": "^7.7.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
